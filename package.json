{
  "name": "redis-predictive-autocomplete",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:server\" \"npm:client\"",
    "server": "node --env-file=.env src/server.js",
    "client": "vite --host 0.0.0.0",
    "seed": "node --env-file=.env scripts/seed.js",
    "generate:data": "node scripts/generate-data.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "redis": "^5.10.0",
    "vite": "^7.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {}
}
